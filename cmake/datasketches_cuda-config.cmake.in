@PACKAGE_INIT@

# GPU-accelerated implementations of Apache Datasketches sketches built on cudax.
# Currently provides HyperLogLog (HLL_8 target type) with binary interop with the
# apache/datasketches-cpp library.
#
# This config resolves the transitive dependencies our INTERFACE target links
# against (CCCL, DataSketches, CUDAToolkit). Consumers only need to call
# `find_package(datasketches_cuda CONFIG)` and link `datasketches::cuda`; the
# CPU `datasketches` target is materialized via find_dependency(DataSketches)
# below, so heterogeneous CPU/GPU code works without a separate find_package.
#
# Note: none of these dependencies are auto-installed by this package, so they
# must be findable on CMAKE_PREFIX_PATH (or otherwise on the find_package
# search path). Consumption via add_subdirectory or CPM does not exercise this
# config file at all and works without any extra setup.

include(CMakeFindDependencyMacro)

find_dependency(CUDAToolkit)
find_dependency(CCCL CONFIG COMPONENTS cudax)
find_dependency(DataSketches CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/datasketches_cuda-targets.cmake")

check_required_components(datasketches_cuda)
